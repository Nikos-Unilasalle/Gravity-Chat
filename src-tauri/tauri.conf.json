{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gravity-Chat",
  "version": "0.1.0",
  "identifier": "com.gravity-chat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gravity Chat",
        "width": 1100,
        "height": 800,
        "transparent": true,
        "windowEffects": { "effects": ["headerView"] }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
